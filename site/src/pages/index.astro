---
import "../styles/global.css";
import BaseLayout from "@grade/astro-kit/BaseLayout.astro";
import { Section, Container } from "@gradeui/ui";
import { SITE, NAV, FONT_HREF } from "../lib/site.config";
import AiToolLogos from "../components/AiToolLogos.astro";

const sectors = ["SaaS", "Mobile apps", "Websites", "Medtech", "Fintech"];

const services = [
  { title: "Design systems", body: "Token architectures, component libraries, and the tooling that keeps design and code in lockstep — from CSS variables up." },
  { title: "Interactive product design", body: "Prototypes and production interfaces built with real components, so what you sign off is what ships." },
  { title: "Front-end engineering", body: "Accessible, performant React and Astro builds that treat the design system as the source of truth." },
  { title: "AI-generated prototypes", body: "Working prototypes generated with AI on top of Grade — real components and real tokens, so an idea becomes a testable product in hours, not weeks." },
];

---

<BaseLayout
  site={SITE}
  nav={NAV}
  fontHref={FONT_HREF}
  title="Pebble Interactive — Systemised design for complex products"
  image="/og.png"
>
  {/* Hero — left-aligned, editorial, mesh-gradient ground */}
  <div class="mesh-hero">
  <Section pad="xl">
    <Container maxW="xl">
      <div class="flex flex-col gap-6">
        <span class="eyebrow">Design systems studio</span>
        <h1 class="text-balance font-display text-4xl leading-[1.04] tracking-tight sm:text-6xl lg:text-7xl">
          Systemised design for complex products
        </h1>
        <p class="max-w-prose text-pretty text-xl leading-relaxed text-muted-foreground">
          Pebble Interactive designs and builds for domains where detail compounds —
          tokens, components, and documentation that hold up as the product grows.
        </p>
      </div>
    </Container>
  </Section>
  </div>

  {/* Services — numbered editorial rows, hairline dividers */}
  <Section pad="lg">
    <Container maxW="xl">
      <span class="eyebrow">What we do</span>
      <div class="mt-6 border-t border-border">
        {services.map((s) => (
          <div class="grid gap-2 border-b border-border py-8 sm:grid-cols-[1fr_1.4fr] sm:gap-8 sm:py-10">
            <h2 class="text-balance font-display text-2xl tracking-tight sm:text-3xl">{s.title}</h2>
            <p class="max-w-prose text-balance text-lg leading-relaxed text-muted-foreground sm:pt-1">{s.body}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  {/* Sectors — inline editorial strip */}
  <Section pad="lg">
    <Container maxW="xl">
      <span class="eyebrow">Where we work</span>
      <p class="mt-6 flex max-w-4xl flex-wrap items-baseline gap-x-3 gap-y-2 font-display text-2xl leading-snug tracking-tight text-foreground sm:text-3xl">
        {sectors.map((s, i) => (
          <span class="whitespace-nowrap">
            {s}
            {i < sectors.length - 1 && <span class="ml-3 text-accent">·</span>}
          </span>
        ))}
      </p>
      <p class="mt-4 max-w-prose text-pretty text-xl leading-relaxed text-muted-foreground">
        From product interfaces to marketing sites — including the regulated, detail-heavy
        worlds of medtech and fintech, where consistency and accessibility aren't optional.
      </p>
    </Container>
  </Section>

  {/* AI-first — tools strip */}
  <Section pad="lg">
    <Container maxW="xl">
      <span class="eyebrow">How we build</span>
      <h2 class="mt-4 max-w-3xl text-balance font-display text-3xl tracking-tight sm:text-4xl">
        An AI-first studio
      </h2>
      <p class="mt-4 max-w-prose text-pretty text-xl leading-relaxed text-muted-foreground">
        AI runs through how we work — from first prototype to production code —
        with a design system keeping every generated screen on brand.
      </p>
      <div class="mt-10">
        <AiToolLogos />
      </div>
    </Container>
  </Section>

  {/* Grade — full-bleed band */}
  <div class="bg-camel">
    <Section pad="xl">
      <Container maxW="xl">
        <div class="grid gap-8 sm:grid-cols-[1.2fr_1fr] sm:items-end">
          <div class="flex flex-col gap-4">
            <span class="eyebrow">Our design system</span>
            <h2 class="text-balance font-display text-4xl leading-[1.05] tracking-tight sm:text-5xl">
              Built on Grade
            </h2>
            <p class="max-w-prose text-pretty text-xl leading-relaxed opacity-80">
              We produce and maintain Grade, our own open design system — the token
              architecture, component library, and AI-assisted studio behind everything
              we ship.
            </p>
          </div>
          <div class="sm:justify-self-end">
            <a
              href="https://gradeui.com"
              class="inline-block border-b border-current pb-1 text-sm font-semibold tracking-wide text-accent transition-opacity hover:opacity-70"
            >
              Explore Grade at gradeui.com →
            </a>
          </div>
        </div>
      </Container>
    </Section>
  </div>

</BaseLayout>
